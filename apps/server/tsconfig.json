{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@ai-learning-os/ai": ["../../packages/ai/src/index.ts"],
      "@ai-learning-os/notion": ["../../packages/notion/src/index.ts"],
      "@ai-learning-os/rag": ["../../packages/rag/src/index.ts"],
      "@ai-learning-os/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
