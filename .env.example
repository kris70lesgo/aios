# OpenRouter (required for AI text + image generation)
OPENROUTER_API_KEY=

# Notion (required for workspace integration)
NOTION_API_KEY=
NOTION_COURSES_DB_ID=
NOTION_TOPICS_DB_ID=
NOTION_PROGRESS_DB_ID=

# Server
PORT=4000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Vector DB (optional — for semantic search over notes)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embeddings (optional — for RAG; OpenAI key or leave blank to skip RAG)
OPENAI_API_KEY=
